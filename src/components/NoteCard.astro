---
import type { CollectionEntry } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import { getNotePath } from "@/utils/getNotePath";

dayjs.extend(utc);

type Props = CollectionEntry<"notes"> & {
  compact?: boolean;
};

const { id, slug, data, compact = false } = Astro.props;
const { title, description, noteDate, location, photos } = data;
const href = getNotePath(id, slug);
const photo = photos[0];
const photoSrc = photo;
const heading = title ?? dayjs.utc(noteDate).format("MMM D, YYYY");
---

<article
  class:list={[
    "grid gap-4 border-b border-dashed border-border py-6 md:grid-cols-[7rem_minmax(0,1fr)]",
    { "md:grid-cols-[5.5rem_minmax(0,1fr)] py-5": compact },
  ]}
>
  <div class="text-sm uppercase tracking-[0.16em] opacity-65">
    <p class="text-2xl font-semibold text-accent">
      {dayjs.utc(noteDate).format("DD")}
    </p>
    <p class="mt-1">{dayjs.utc(noteDate).format("MMM YYYY")}</p>
  </div>

  <a
    href={href}
    class:list={[
      "group block border border-border bg-muted/18 p-5 transition hover:border-accent/30 hover:bg-muted/30",
      { "p-4": compact },
    ]}
  >
    {location && (
      <div class="text-xs font-medium uppercase tracking-[0.16em] opacity-65">
        {location}
      </div>
    )}

    <h2 class="mt-3 text-xl font-semibold text-accent">{heading}</h2>
    <p class="mt-3 leading-7 opacity-80">{description}</p>

    {
      photoSrc && (
        <div class="mt-4 overflow-hidden border border-border/70">
          <img
            src={photoSrc}
            alt={heading}
            class="h-52 w-full object-cover transition duration-300 group-hover:scale-[1.02]"
            loading="lazy"
          />
        </div>
      )
    }

    <div class="mt-4 text-sm font-medium opacity-70 transition group-hover:text-accent">
      Open note →
    </div>
  </a>
</article>
