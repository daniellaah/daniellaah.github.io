---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import IconCalendar from "@/assets/icons/IconCalendar.svg";

dayjs.extend(utc);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  modDatetime?: string | Date | null;
  showBothDates?: boolean;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  showBothDates = false,
  class: className = "",
} = Astro.props;

// Date-only frontmatter like 2026-03-05 should stay on that calendar day.
// Using UTC here avoids shifting to the previous day in America/Los_Angeles.
const publishedDatetime = dayjs.utc(pubDatetime);
const modifiedDatetime = modDatetime ? dayjs.utc(modDatetime) : null;
const publishedDate = publishedDatetime.format("YYYY-MM-DD");
const modifiedDate = modifiedDatetime?.format("YYYY-MM-DD");
const showUpdatedDate = Boolean(modifiedDate && modifiedDate !== publishedDate);
---

<div class:list={["flex items-center gap-x-2 opacity-80", className]}>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-5.5",
      { "scale-90": size === "sm" },
    ]}
  />
  {
    showBothDates ? (
      <div
        class:list={[
          "flex flex-wrap items-center gap-x-3 gap-y-1",
          "text-sm",
          { "sm:text-base": size === "lg" },
        ]}
      >
        <time datetime={publishedDatetime.toISOString()}>{publishedDate}</time>
        {
          showUpdatedDate && modifiedDatetime && (
            <>
              <span aria-hidden="true" class="opacity-40">•</span>
              <span class="text-xs font-medium tracking-[0.14em] uppercase opacity-60">
                updated
              </span>
              <time datetime={modifiedDatetime.toISOString()}>{modifiedDate}</time>
            </>
          )
        }
      </div>
    ) : (
      <time
        class:list={["text-sm", { "sm:text-base": size === "lg" }]}
        datetime={publishedDatetime.toISOString()}
      >
        {publishedDate}
      </time>
    )
  }
</div>
