---
type Props = {
  status: "active" | "shipping" | "archived" | "lab";
};

const { status } = Astro.props;

const labelMap = {
  active: "Active",
  shipping: "Shipping",
  archived: "Archived",
  lab: "Lab",
} as const;

const styleMap = {
  active: "border-accent/30 bg-accent/8 text-accent",
  shipping: "border-emerald-600/25 bg-emerald-600/8 text-emerald-700 dark:text-emerald-400",
  archived: "border-border bg-muted/45 text-foreground/70",
  lab: "border-amber-600/25 bg-amber-600/8 text-amber-700 dark:text-amber-400",
} as const;
---

<span
  class:list={[
    "inline-flex items-center rounded-full border px-2.5 py-1 text-[11px] font-semibold tracking-[0.16em] uppercase",
    styleMap[status],
  ]}
>
  {labelMap[status]}
</span>
