---
import type { CollectionEntry } from "astro:content";
import ProjectStatusBadge from "./ProjectStatusBadge.astro";
import { getProjectPath } from "@/utils/getProjectPath";

type Props = CollectionEntry<"projects"> & {
  compact?: boolean;
};

const { id, data, compact = false } = Astro.props;
const { title, description, status, stack, year } = data;
const href = getProjectPath(id);
const visibleStack = compact ? stack.slice(0, 3) : stack.slice(0, 4);
---

<article
  class:list={[
    "group py-6 transition duration-200",
    { "p-5": compact },
  ]}
>
  <div>
    <div class="flex items-baseline gap-4">
      <h2 class="min-w-0 text-2xl font-semibold text-accent">
        <a href={href} class="hover:underline decoration-dashed underline-offset-4">
          {title}
        </a>
      </h2>
    </div>

    <div class="mt-4 flex flex-wrap items-center gap-3">
      <ProjectStatusBadge status={status} />
      {year && <span class="text-sm opacity-65">{year}</span>}
      {
        visibleStack.length > 0 && (
          <ul class="flex flex-nowrap gap-2 overflow-x-auto md:overflow-visible">
            {visibleStack.map(item => (
              <li class="rounded-full bg-muted/55 px-3 py-1 text-xs font-medium whitespace-nowrap">
                {item}
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <div>
      <p class="mt-3 max-w-3xl text-sm leading-7 opacity-80">{description}</p>
    </div>
  </div>
</article>
