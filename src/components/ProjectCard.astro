---
import type { CollectionEntry } from "astro:content";
import ProjectStatusBadge from "./ProjectStatusBadge.astro";
import { getProjectPath } from "@/utils/getProjectPath";

type Props = CollectionEntry<"projects"> & {
  compact?: boolean;
};

const { id, data, compact = false } = Astro.props;
const { title, description, status, stack, year } = data;
const href = getProjectPath(id);
const visibleStack = compact ? stack.slice(0, 3) : stack.slice(0, 4);
---

<article
  class:list={[
    "group relative overflow-hidden rounded-[2rem] border border-border bg-background p-6 transition duration-200 hover:-translate-y-1 hover:border-accent/35 hover:shadow-[0_20px_60px_rgba(18,57,91,0.08)]",
    { "p-5": compact },
  ]}
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-linear-to-b from-accent/12 via-accent/4 to-transparent"
  />
  <div class="relative">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <ProjectStatusBadge status={status} />
      {year && <span class="text-sm opacity-65">{year}</span>}
    </div>

    <h2 class="mt-5 text-2xl font-semibold text-accent">
      <a href={href} class="after:absolute after:inset-0">{title}</a>
    </h2>

    <p class="mt-3 text-sm leading-7 opacity-80">{description}</p>

    {
      visibleStack.length > 0 && (
        <ul class="mt-5 flex flex-wrap gap-2">
          {visibleStack.map(item => (
            <li class="rounded-full bg-muted/55 px-3 py-1 text-xs font-medium">
              {item}
            </li>
          ))}
        </ul>
      )
    }

    <div class="mt-6 flex items-center justify-between text-sm font-medium">
      <span class="opacity-70">View details</span>
      <span class="text-accent transition group-hover:translate-x-1">→</span>
    </div>
  </div>
</article>
