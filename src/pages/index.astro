---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const focusAreas = [
  {
    title: "Frontend Engineering",
    body: "界面实现、设计系统、性能和长期可维护的前端架构。",
  },
  {
    title: "AI Workflow",
    body: "把 AI 真正接入写代码、写文档和做项目的实际流程，而不是停留在 demo。",
  },
  {
    title: "Build in Public",
    body: "记录项目从想法到交付的判断、取舍、失败和可复用经验。",
  },
];
const principles = [
  "写真实问题，不写空泛总结。",
  "优先记录取舍和判断，而不是只贴结果。",
  "让文章保持独立成立，而不是为了形式去重复改写。",
];
---

<Layout lang="zh-CN">
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section
      id="hero"
      class:list={[
        "grid gap-8 border-b border-border pt-10 pb-8 sm:pt-14",
        "lg:grid-cols-[minmax(0,1.5fr)_minmax(18rem,0.9fr)]",
      ]}
    >
      <div>
        <div class="flex items-center gap-3">
          <h1 class="inline-block text-4xl font-bold sm:text-6xl">
            Bo's Blog
          </h1>
          <a
            target="_blank"
            href="/rss.xml"
            class="inline-block"
            aria-label="rss feed"
            title="RSS Feed"
          >
            <IconRss
              width={20}
              height={20}
              class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
            />
            <span class="sr-only">RSS Feed</span>
          </a>
        </div>
        <p class="mt-6 max-w-2xl text-lg leading-8">
          我用这个博客记录前端工程、AI 工作流和个人项目里的真实决策。
          这里不是模板说明书，而是长期积累自己的技术判断。
        </p>
        <p class="mt-3 max-w-2xl text-base leading-7 opacity-80">
          Focused on concrete problems, reusable patterns, and work that
          survives beyond a single demo.
        </p>
        <div class="mt-6 flex flex-wrap gap-x-6 gap-y-3 text-sm font-medium">
          <span>Astro + Vercel</span>
          <span>Frontend + AI + Projects</span>
        </div>
        <div class="mt-7 flex flex-wrap gap-4">
          <LinkButton
            href="/posts/"
            class="rounded-full border border-border px-5 py-2.5 hover:border-accent"
          >
            Read Posts
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
          <LinkButton
            href="/about/"
            class="rounded-full border border-border px-5 py-2.5 hover:border-accent"
          >
            About Bo
          </LinkButton>
        </div>
      </div>

      <aside class="rounded-3xl border border-border p-5 sm:p-6">
        <p class="text-sm font-medium tracking-[0.18em] text-accent uppercase">
          Right Now
        </p>
        <ul class="mt-4 space-y-4 text-sm leading-7">
          <li>
            Building a personal blog on top of Astro Paper and reshaping it
            into a more personal publishing system.
          </li>
          <li>
            Writing about frontend engineering, AI-assisted development, and
            the tradeoffs behind side projects.
          </li>
          <li>
            Keeping the stack simple: Markdown content, GitHub workflow, and
            Vercel deployment.
          </li>
        </ul>
        {
          SOCIALS.length > 0 && (
            <div class="mt-5 border-t border-border pt-4">
              <p class="mb-2 text-xs tracking-[0.18em] uppercase opacity-70">
                Find me
              </p>
              <Socials />
            </div>
          )
        }
      </aside>
    </section>

    <section
      id="focus"
      class="grid gap-4 border-b border-border py-8 sm:grid-cols-3"
    >
      {
        focusAreas.map(item => (
          <article class="rounded-3xl border border-border p-5">
            <h2 class="text-xl font-semibold">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 opacity-80">{item.body}</p>
          </article>
        ))
      }
    </section>

    <section
      id="principles"
      class="grid gap-8 border-b border-border py-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]"
    >
      <div>
        <p class="text-sm font-medium tracking-[0.18em] text-accent uppercase">
          What This Blog Is For
        </p>
        <h2 class="mt-3 text-2xl font-semibold sm:text-3xl">
          A place to think in public without writing like a changelog.
        </h2>
        <p class="mt-4 max-w-2xl leading-8 opacity-85">
          我希望这里保留下来的不是零散笔记，而是经得起回看的工程经验。
          每篇文章都应该回答一个具体问题，解释一次真实取舍，或者沉淀一种可复用的方法。
        </p>
      </div>
      <div class="rounded-3xl bg-muted/35 p-5">
        <p class="text-sm font-medium tracking-[0.18em] uppercase opacity-80">
          Writing Principles
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-7">
          {principles.map(item => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Latest Writing</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        Browse All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
