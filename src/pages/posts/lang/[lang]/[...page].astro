---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Pagination from "@/components/Pagination.astro";
import PostsList from "@/components/PostsList.astro";
import LanguageNav from "@/components/LanguageNav.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import {
  getLanguageMeta,
  getLanguagePosts,
} from "@/utils/language";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const sortedPosts = getSortedPosts(posts);

  return SITE.supportedLangs.flatMap(lang => {
    const meta = getLanguageMeta(lang);
    const languagePosts = getLanguagePosts(sortedPosts, lang);

    return paginate(languagePosts, {
      params: { lang: meta.path },
      props: { language: lang },
      pageSize: SITE.postPerPage,
    });
  });
}

const { page, language } = Astro.props;
const meta = getLanguageMeta(language);
---

<Layout title={`Posts | ${SITE.title}`} lang={language}>
  <Header />
  <Main pageTitle="Posts" pageDesc="Browse all posts and filter by language.">
    <LanguageNav currentHref={`/posts/lang/${meta.path}/`} />
    <PostsList posts={page.data} />
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
