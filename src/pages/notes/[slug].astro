---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BackButton from "@/components/BackButton.astro";
import IconLocation from "@/assets/icons/IconLocation.svg";
import getSortedNotes from "@/utils/getSortedNotes";
import { getNotePath } from "@/utils/getNotePath";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

dayjs.extend(utc);

export const getStaticPaths = (async () => {
  const notes = getSortedNotes(await getCollection("notes"));

  return notes.map(note => ({
    params: { slug: getNotePath(note.id, note.slug).split("/").at(-1) },
    props: { note },
  }));
}) satisfies GetStaticPaths;

const { note } = Astro.props;
const { Content } = await render(note);

const { title, description, noteDate, modDatetime, lang, location, tags, photos, canonicalURL } =
  note.data;

const heading = title ?? dayjs.utc(noteDate).format("MMM D, YYYY");
const heroImage = photos[0];
const heroImageSrc = heroImage;
const createdDate = dayjs.utc(noteDate).format("YYYY-MM-DD");
const updatedDate = modDatetime ? dayjs.utc(modDatetime).format("YYYY-MM-DD") : null;
const showUpdatedDate = Boolean(updatedDate && updatedDate !== createdDate);
---

<Layout
  title={`${heading} | Notes | ${SITE.title}`}
  description={description}
  lang={lang}
  canonicalURL={canonicalURL}
  ogImage={heroImageSrc}
  pubDatetime={noteDate}
  modDatetime={modDatetime}
>
  <Header />
  <BackButton />
  <main id="main-content" class="app-layout pb-12" data-pagefind-body>
    <section
      class:list={[
        "grid gap-8 border-b border-border pb-8 lg:grid-cols-[8rem_minmax(0,1fr)]",
        showUpdatedDate ? "items-start" : "items-stretch",
      ]}
    >
      <div
        class:list={[
          "border border-border bg-muted/20 p-4",
          showUpdatedDate
            ? "self-start"
            : "flex items-center justify-center lg:h-full",
        ]}
      >
        {
          showUpdatedDate ? (
            <div class="text-left">
              <p class="text-[0.65rem] font-medium tracking-[0.16em] uppercase opacity-60">
                Created
              </p>
              <p class="mt-1 text-sm font-semibold text-accent sm:text-base">
                {createdDate}
              </p>
              <div class="mt-3 border-t border-border/70 pt-3">
                <p class="text-[0.6rem] font-medium tracking-[0.16em] uppercase opacity-55">
                  Updated
                </p>
                <p class="mt-1 text-xs font-medium opacity-75 sm:text-sm">
                  {updatedDate}
                </p>
              </div>
            </div>
          ) : (
            <div class="text-center">
              <p class="text-3xl font-semibold text-accent">
                {dayjs.utc(noteDate).format("DD")}
              </p>
              <p class="mt-2 text-xs uppercase tracking-[0.16em] opacity-65">
                {dayjs.utc(noteDate).format("MMM YYYY")}
              </p>
            </div>
          )
        }
      </div>

      <div class="flex min-h-full flex-col pt-1">
        {
          location && (
            <p class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.16em] opacity-65">
              <IconLocation aria-hidden="true" class="size-4 shrink-0" />
              <span aria-hidden="true">•</span>
              <span>{location}</span>
            </p>
          )
        }
        <h1 class="mt-3 text-3xl font-semibold text-accent sm:text-4xl">
          {heading}
        </h1>
        {
          tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 md:mt-auto md:pt-4">
              {tags.map(tag => (
                <li>
                  <a
                    href={`/tags/${slugifyStr(tag)}/`}
                    class="text-sm font-medium tracking-[0.12em] text-accent/85 transition hover:text-accent"
                  >
                    #{tag}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>
    </section>

    {
      heroImageSrc && (
        <div class="mt-8 overflow-hidden border border-border">
          <img
            src={heroImageSrc}
            alt={heading}
            class="max-h-[34rem] w-full object-cover"
          />
        </div>
      )
    }

    <article class="app-prose mt-8 w-full max-w-app">
      <Content />
    </article>

    {
      photos.length > 1 && (
        <section class="mt-10 border-t border-border pt-8">
          <h2 class="text-2xl font-semibold">More Photos</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {photos.slice(1).map(photo => {
              const src = photo;
              return (
                <div class="overflow-hidden border border-border">
                  <img src={src} alt={heading} class="h-72 w-full object-cover" />
                </div>
              );
            })}
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>
