---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import NoteCard from "@/components/NoteCard.astro";
import getSortedNotes from "@/utils/getSortedNotes";
import { SITE } from "@/config";

const notes = getSortedNotes(await getCollection("notes"));
---

<Layout title={`Notes | ${SITE.title}`} description="Short notes on experiments, study logs, runs, and lighter thoughts from Bo.">
  <Header />
  <Main pageTitle="Notes">
    {
      notes.length > 0 ? (
        <section>
          {notes.map(note => <NoteCard {...note} />)}
        </section>
      ) : (
        <section class="border border-border bg-muted/20 p-8">
          <h2 class="text-2xl font-semibold">No notes published yet.</h2>
          <p class="mt-3 max-w-2xl leading-8 opacity-80">
            Add Markdown files under <code>src/content/notes</code> to start a
            memo stream.
          </p>
        </section>
      )
    }
  </Main>
  <Footer />
</Layout>
